<div class="care-recipient-basic panel">
  <% if @care_recipient.photo.attached? %>
    <%= image_tag @care_recipient.photo.variant(resize_to_fill: [150, 150]), class: "care-photo", alt: @care_recipient.name %>
  <% else %>
    <div class="care-photo care-photo-placeholder" aria-hidden="true"><%= @care_recipient.name.to_s.first %></div>
  <% end %>

  <h2><%= @care_recipient.name %></h2>
  <p><strong>生年月日:</strong> <%= @care_recipient.birthday %>(<%= @care_recipient.age %>歳)</p>
  <p><strong>住所:</strong> <%= @care_recipient.address %></p>
  <p><strong>介護度:</strong> <%= value_or_unset(@care_recipient.care_level) %></p>
  <p>
    <strong>認定有効期限:</strong>
    <% if @care_recipient.care_level_valid_until %>
      <%= @care_recipient.care_level_valid_until %>
      <% if @care_recipient.certification_expired? %>
        <span class="status-badge critical">期限切れ</span>
      <% elsif @care_recipient.certification_expiring? %>
        <span class="status-badge warning">まもなく期限切れ</span>
      <% end %>
    <% else %>
      <span class="text-unset">未設定</span>
    <% end %>
  </p>
  <p><strong>担当ケアマネージャー:</strong> <%= @care_recipient.primary_care_manager&.name || content_tag(:span, "未設定", class: "text-unset") %></p>

  <div class="actions">
    <%= link_to "編集", edit_care_recipient_path(@care_recipient), class: "btn btn-edit" %>
    <%= link_to "対象者一覧に戻る", care_recipients_path, class: "btn btn-show" %>
    <%= button_to "削除", @care_recipient, method: :delete, data: { confirm: "削除しますか？" }, class: "btn btn-delete" %>
  </div>
</div>

<div class="medical-info panel">
  <h3>医療・介護情報</h3>
  <p><strong>かかりつけ医:</strong> <%= value_or_unset(@care_recipient.primary_doctor) %></p>
  <p><strong>かかりつけ医療機関:</strong> <%= value_or_unset(@care_recipient.primary_hospital) %></p>
  <p><strong>既往歴:</strong> <%= value_or_unset(@care_recipient.medical_history) %></p>
  <p><strong>現在服用中の薬:</strong> <%= value_or_unset(@care_recipient.regular_medications) %></p>
  <p><strong>アレルギー:</strong> <%= value_or_unset(@care_recipient.allergies) %></p>
  <p><strong>メモ:</strong> <%= value_or_unset(@care_recipient.memo) %></p>
</div>

<div class="emergency-contacts panel">
  <h3>緊急連絡先</h3>

  <% if @care_recipient.emergency_contacts.any? %>
    <ul>
      <% @care_recipient.emergency_contacts.each do |contact| %>
        <li>
          <%= contact.name %>(<%= contact.relationship %>) <%= contact.phone_number %>
          <% if contact.note.present? %> - <%= contact.note %><% end %>
          <% if policy(@care_recipient).update? %>
            <%= link_to "編集", edit_care_recipient_emergency_contact_path(@care_recipient, contact) %>
            <%= button_to "削除", care_recipient_emergency_contact_path(@care_recipient, contact),
                  method: :delete, data: { confirm: "この緊急連絡先を削除しますか？" }, class: "btn btn-delete" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>登録された緊急連絡先はありません</p>
  <% end %>

  <% if policy(@care_recipient).update? %>
    <%= link_to "緊急連絡先を追加", new_care_recipient_emergency_contact_path(@care_recipient), class: "btn btn-show" %>
  <% end %>
</div>

<div class="care-documents panel">
  <h3>書類</h3>
  <p>リハビリ実施計画書・居宅サービス計画書・通所介護計画書など、事業所外で作成された公式書類を保管します。</p>
  <p><%= link_to "書類一覧を見る", care_recipient_care_documents_path(@care_recipient), class: "btn btn-show" %></p>
</div>

<% if policy(SupportLog.new(care_recipient: @care_recipient)).index? %>
  <div class="support-logs panel">
    <h3>支援経過記録</h3>
    <p>電話連絡・他機関との調整・家族対応など、訪問を伴わないやり取りを時系列で記録します(家族には非公開)。</p>
    <p><%= link_to "支援経過記録を見る", care_recipient_support_logs_path(@care_recipient), class: "btn btn-show" %></p>
  </div>
<% end %>

<div class="health-trends panel">
  <h3>健康推移</h3>
  <ul>
    <li><%= link_to "バイタル(血圧・脈拍・体温・体重・血糖値)", care_recipient_vitals_path(@care_recipient) %></li>
    <li><%= link_to "ADL記録(食事・排泄・睡眠)", care_recipient_adl_records_path(@care_recipient) %></li>
    <li><%= link_to "服薬記録", care_recipient_medication_records_path(@care_recipient) %></li>
  </ul>

  <% if @recent_records.present? %>
    <h4>最近の記録</h4>
    <ul>
      <% @recent_records.each do |record| %>
        <li><%= l(record[:recorded_at], format: :short) if record[:recorded_at] %> [<%= record[:type] %>] <%= record[:summary] %></li>
      <% end %>
    </ul>
  <% end %>
</div>

<% if policy(@care_recipient).update? %>
  <div class="family-memberships panel">
    <h3>家族アカウントの紐付け</h3>

    <% if @care_recipient.family_memberships.any? %>
      <ul>
        <% @care_recipient.family_memberships.includes(:user).each do |membership| %>
          <li>
            <%= membership.user.name %>(<%= membership.user.email %>)
            <%= button_to "解除", care_recipient_family_membership_path(@care_recipient, membership),
                  method: :delete, data: { confirm: "この家族の紐付けを解除しますか？" }, class: "btn btn-delete" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>紐付けられた家族アカウントはありません</p>
    <% end %>

    <% available_family_users = User.family.where.not(id: @care_recipient.family_members.select(:id)) %>
    <% if available_family_users.any? %>
      <%= form_with url: care_recipient_family_memberships_path(@care_recipient), method: :post, scope: :family_membership do |f| %>
        <%= f.select :user_id, available_family_users.map { |u| ["#{u.name} (#{u.email})", u.id] } %>
        <%= f.submit "家族として追加", class: "btn btn-show" %>
      <% end %>
    <% else %>
      <p>紐付け可能な家族アカウント(familyロール)がありません</p>
    <% end %>
  </div>
<% end %>
