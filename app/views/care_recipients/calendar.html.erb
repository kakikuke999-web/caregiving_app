<% can_manage_visits = policy(VisitReport.new(care_recipient: @care_recipient)).create? %>
<% can_manage_schedules = policy(@care_recipient.personal_schedules.new).create? %>
<% has_calendar_actions = can_manage_schedules || current_user.admin? || current_user.care_manager? || current_user.staff? %>

<h2><%= @care_recipient.name %> さんの訪問予定・実績</h2>

<div class="panel">
  <div class="calendar-legend">
    <span class="status-dot" style="background: <%= VisitReportsController::STATUS_COLORS["planned"] %>"></span>予定
    <span class="status-dot" style="background: <%= VisitReportsController::STATUS_COLORS["completed"] %>"></span>完了
    <span class="status-dot" style="background: <%= VisitReportsController::STATUS_COLORS["missed"] %>"></span>未実施
    <span class="status-dot" style="background: <%= PersonalSchedulesController::COLOR %>"></span>本人の予定
  </div>

  <% if has_calendar_actions %>
    <div class="calendar-actions-wrap">
      <input type="checkbox" id="calendar-actions-toggle" class="calendar-actions-toggle-checkbox">
      <label for="calendar-actions-toggle" class="calendar-actions-toggle-btn">操作メニュー ▾</label>

      <div class="calendar-actions">
        <% if can_manage_schedules %>
          <%= link_to "本人の予定を追加", new_care_recipient_personal_schedule_path(@care_recipient), class: "btn btn-show" %>
        <% end %>

        <% if current_user.admin? || current_user.care_manager? || current_user.staff? %>
          <%= link_to "訪問実績を記録", new_care_recipient_daily_report_path(@care_recipient), class: "btn btn-show" %>
        <% end %>

        <% if current_user.admin? %>
          <%= link_to "日誌を一括インポート", new_care_recipient_daily_report_import_path(@care_recipient), class: "btn btn-show" %>
        <% end %>

        <% if current_user.admin? || current_user.care_manager? || current_user.staff? %>
          <%= link_to "定期予定を管理", care_recipient_recurring_schedules_path(@care_recipient), class: "btn btn-show" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div id="calendar" data-care-recipient-id="<%= @care_recipient.id %>"
       data-can-manage-visits="<%= can_manage_visits %>"
       data-can-manage-schedules="<%= can_manage_schedules %>"></div>
</div>

<!-- モーダル構造（Bootstrap 5） -->
<div class="modal fade" id="eventModal" tabindex="-1" aria-labelledby="eventModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="eventModalLabel">予定詳細</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="閉じる"></button>
      </div>
      <div class="modal-body" id="modal-body">
        <!-- JavaScriptで内容を埋め込む -->
      </div>
    </div>
  </div>
</div>


<script>
  document.addEventListener('DOMContentLoaded', function () {
    const calendarEl = document.getElementById('calendar');
    const careRecipientId = calendarEl.dataset.careRecipientId;
    const canManageVisits = calendarEl.dataset.canManageVisits === 'true';
    const canManageSchedules = calendarEl.dataset.canManageSchedules === 'true';

    function editEndpointFor(props) {
      if (props.kind === 'personal_schedule') {
        return `/care_recipients/${careRecipientId}/personal_schedules/${props.id}/edit`;
      }
      return canManageVisits ? `/visit_reports/${props.id}/edit` : `/visit_reports/${props.id}`;
    }

    function openEventModal(props) {
      fetch(editEndpointFor(props), { headers: { 'Accept': 'text/vnd.turbo-stream.html' } })
        .then(response => response.text())
        .then(html => {
          document.getElementById('modal-body').innerHTML = html;
          document.getElementById('eventModalLabel').textContent = '予定詳細';
          new bootstrap.Modal(document.getElementById('eventModal')).show();
        });
    }

    // 月表示は日付セルを点だけにして30日分をスクロールなしで収めているため、
    // 日付をタップした時にその日の予定一覧をここで見せる（週表示は各予定が
    // すでに全文表示されているので使わない）。
    function openDayList(dateStr, events) {
      const items = events.map(function (event) {
        const time = event.allDay ? '' : event.start.toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit', timeZone: 'UTC' });
        return `<button type="button" class="day-list-item" data-event-id="${event.id}" style="border-left-color: ${event.backgroundColor}">
                  <span class="day-list-time">${time}</span>
                  <span class="day-list-title">${event.title}</span>
                </button>`;
      }).join('');

      const addLink = canManageVisits
        ? `<a class="btn btn-show" href="/visit_reports/new?care_recipient_id=${careRecipientId}&visited_at=${dateStr}">＋この日に訪問記録を追加</a>`
        : (canManageSchedules
          ? `<a class="btn btn-show" href="/care_recipients/${careRecipientId}/personal_schedules/new?started_at=${dateStr}">＋この日に予定を追加</a>`
          : '');

      document.getElementById('modal-body').innerHTML = `<div class="day-list">${items}</div><div class="day-list-actions">${addLink}</div>`;
      document.getElementById('eventModalLabel').textContent = `${dateStr} の予定`;

      document.querySelectorAll('#modal-body .day-list-item').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const ev = calendar.getEventById(btn.dataset.eventId);
          openEventModal(ev.extendedProps);
        });
      });

      new bootstrap.Modal(document.getElementById('eventModal')).show();
    }

    const isNarrowScreen = window.matchMedia('(max-width: 600px)').matches;

    const calendar = new FullCalendar.Calendar(calendarEl, {
      plugins: [FullCalendar.DayGrid.default, FullCalendar.List.default, FullCalendar.Interaction.default],
      initialView: 'dayGridMonth',
      locale: 'ja',
      // config.time_zone is unset (=UTC) app-wide, so every stored/displayed timestamp is a literal
      // wall-clock value already. FullCalendar's default timeZone:'local' would re-convert using the
      // browser's zone (JST), shifting times by +9h and sometimes pushing long visits into the next day.
      timeZone: 'UTC',
      headerToolbar: { left: 'title', center: '', right: 'today prev,next dayGridMonth,listWeek' },
      buttonText: { today: '今日', dayGridMonth: '月間', listWeek: '週間' },
      dayMaxEventRows: isNarrowScreen ? false : 3,
      eventSources: [
        `/care_recipients/${careRecipientId}/visit_events`,
        `/care_recipients/${careRecipientId}/personal_schedule_events`
      ],

      // スマホの月表示だけ、予定を色付きの点に簡略化して30日分を縦スクロールなしで表示する。
      // 週表示・デスクトップの月表示は通常どおり時刻＋内容を表示する。
      eventContent: function (arg) {
        if (arg.view.type === 'dayGridMonth' && isNarrowScreen) {
          return { html: `<span class="fc-daygrid-dot" style="background:${arg.event.backgroundColor}"></span>` };
        }
        return true;
      },

      dateClick: function (info) {
        if (info.view.type !== 'dayGridMonth') return;

        const dayEvents = calendar.getEvents().filter(function (e) { return e.startStr.slice(0, 10) === info.dateStr; });
        if (dayEvents.length > 0) {
          openDayList(info.dateStr, dayEvents);
          return;
        }

        if (canManageVisits) {
          window.location.href = `/visit_reports/new?care_recipient_id=${careRecipientId}&visited_at=${info.dateStr}`;
        } else if (canManageSchedules) {
          window.location.href = `/care_recipients/${careRecipientId}/personal_schedules/new?started_at=${info.dateStr}`;
        }
      },

      eventClick: function (info) {
        openEventModal(info.event.extendedProps);
      }
    });

    calendar.render();
  });
</script>
