<%= form_with(model: care_recipient) do |form| %>
  <% if care_recipient.errors.any? %>
    <div style="color: red">
      <h2><%= care_recipient.errors.count %>件のエラーにより保存できませんでした:</h2>

      <ul>
        <% care_recipient.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- 氏名 -->
  <div>
    <%= form.label :name, "氏名", style: "display: block" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <!-- フリガナ -->
  <div>
    <%= form.label :name_kana, "フリガナ", style: "display: block" %>
    <%= form.text_field :name_kana, class: "form-control" %>
  </div>

  <!-- 性別 -->
  <div>
    <%= form.label :gender, "性別", style: "display: block" %>
    <%= form.select :gender, CareRecipient::GENDERS.map { |g| [CareRecipient::GENDER_LABELS[g], g] }, prompt: "選択してください", class: "form-control" %>
  </div>

  <!-- 生年月日 -->
  <div>
    <%= form.label :birthday, "生年月日", style: "display: block" %>
    <%= form.date_select :birthday,
          start_year: 1920,
          end_year: Date.today.year,
          default: Date.new(1960, 1, 1),
          use_month_numbers: true,
          class: "form-control" %>
  </div>

  <!-- 住所（大きく） -->
  <div>
    <%= form.label :address, "住所", style: "display: block" %>
    <%= form.text_field :address, class: "form-control address-field" %>
  </div>

  <!-- かかりつけ医 -->
  <div>
    <%= form.label :primary_doctor, "かかりつけ医", style: "display: block" %>
    <%= form.text_field :primary_doctor, class: "form-control" %>
  </div>

  <!-- かかりつけ医療機関 -->
  <div>
    <%= form.label :primary_hospital, "かかりつけ医療機関", style: "display: block" %>
    <%= form.text_field :primary_hospital, class: "form-control" %>
  </div>

  <!-- 既往歴 -->
  <div>
    <%= form.label :medical_history, "既往歴", style: "display: block" %>
    <%= form.text_area :medical_history, rows: 4, class: "form-control" %>
  </div>

  <!-- 現在服用中の薬 -->
  <div>
    <%= form.label :regular_medications, "現在服用中の薬", style: "display: block" %>
    <%= form.text_area :regular_medications, rows: 4, class: "form-control" %>
  </div>

  <!-- アレルギー -->
  <div>
    <%= form.label :allergies, "アレルギー", style: "display: block" %>
    <%= form.text_area :allergies, rows: 3, class: "form-control" %>
  </div>

  <!-- 介護度 -->
  <div>
    <%= form.label :care_level, "介護度", style: "display: block" %>
    <%= form.select :care_level, CareRecipient::CARE_LEVELS, prompt: "選択してください", class: "form-control" %>
  </div>

  <!-- 認定有効期限 -->
  <div>
    <%= form.label :care_level_valid_until, "認定有効期限", style: "display: block" %>
    <%= form.date_field :care_level_valid_until, class: "form-control" %>
  </div>

  <!-- 担当ケアマネージャー -->
  <div>
    <%= form.label :primary_care_manager_id, "担当ケアマネージャー", style: "display: block" %>
    <%= form.collection_select :primary_care_manager_id, User.where(role: [:admin, :care_manager]).order(:name), :id, :name, { prompt: "選択してください" }, class: "form-control" %>
  </div>

  <!-- サービス利用票用の保険情報 -->
  <div class="field-row">
    <div class="field-col">
      <%= form.label :insurer_number, "保険者番号", style: "display: block" %>
      <%= form.text_field :insurer_number, class: "form-control" %>
    </div>
    <div class="field-col">
      <%= form.label :insured_person_number, "被保険者番号", style: "display: block" %>
      <%= form.text_field :insured_person_number, class: "form-control" %>
    </div>
    <div class="field-col">
      <%= form.label :benefit_limit_units, "区分支給限度基準額(単位/月)", style: "display: block" %>
      <%= form.number_field :benefit_limit_units, class: "form-control" %>
    </div>
  </div>

  <!-- 利用する訪問タイプ -->
  <div>
    <%= form.label :visit_type_ids, "利用する訪問タイプ", style: "display: block" %>
    <% if VisitType.any? %>
      <div class="check-box-group">
        <%= form.collection_check_boxes :visit_type_ids, VisitType.order(:name), :id, :name %>
      </div>
    <% else %>
      <p>訪問タイプが登録されていません。<%= link_to "訪問タイプ管理", visit_types_path %>から登録してください。</p>
    <% end %>
  </div>

  <!-- メモ（大きく） -->
  <div>
    <%= form.label :memo, "メモ", style: "display: block" %>
    <%= form.text_area :memo, rows: 8, class: "form-control memo-field" %>
  </div>


  <!-- 写真アップロード（ドラッグ＆ドロップ対応） -->
  <div class="photo-upload-area" id="photo-drop-area">
    <p>ここに写真をドラッグ＆ドロップ</p>

    <%= form.file_field :photo, id: "photo-input", style: "display:none;" %>

    <button type="button" id="photo-select-btn">ファイルを選択</button>

    <div id="photo-preview">
      <% if care_recipient.photo.attached? %>
        <%= image_tag care_recipient.photo.variant(resize_to_fill: [150, 150]), class: "care-photo" %>
      <% end %>
    </div>
  </div>

  <% if care_recipient.photo.attached? %>
    <div style="margin-top: 10px;">
      <label>
        <%= form.check_box :remove_photo %>
        写真を削除する
      </label>
    </div>
  <% end %>

  <!-- 送信ボタン -->
  <div>
    <%= form.submit "登録する", class: "btn btn-new" %>
  </div>
<% end %>
