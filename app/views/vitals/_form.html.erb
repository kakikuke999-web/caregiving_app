<%= form_with model: [care_recipient, vital], local: true do |f| %>
  <% if vital.errors.any? %>
    <div class="alert alert-danger">
      <h2><%= pluralize(vital.errors.count, "error") %> prohibited this vital from being saved:</h2>
      <ul>
        <% vital.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :type, "項目" %>
    <%= f.select :type, Vital::TYPES.map { |t| [Vital::LABELS[t], t] }, { prompt: "選択してください" }, class: "form-select", id: "vital_type_select" %>
  </div>

  <div class="mb-3" id="vital-value-field">
    <%= f.label :value, "値" %>
    <%= f.number_field :value, step: "0.1", class: "form-control" %>
  </div>

  <div class="mb-3" id="vital-bp-fields">
    <%= f.label :systolic, "収縮期(上)" %>
    <%= f.number_field :systolic, class: "form-control" %>
    <%= f.label :diastolic, "拡張期(下)" %>
    <%= f.number_field :diastolic, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :recorded_at, "記録日時" %>
    <%= f.datetime_select :recorded_at, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :note, "メモ" %>
    <%= f.text_area :note, class: "form-control" %>
  </div>

  <%= f.submit "保存", class: "btn btn-primary" %>
<% end %>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const select = document.getElementById('vital_type_select');
    const valueField = document.getElementById('vital-value-field');
    const bpFields = document.getElementById('vital-bp-fields');
    if (!select) return;

    function toggle() {
      const isBp = select.value === 'blood_pressure';
      valueField.style.display = isBp ? 'none' : 'block';
      bpFields.style.display = isBp ? 'block' : 'none';
    }

    select.addEventListener('change', toggle);
    toggle();
  });
</script>
