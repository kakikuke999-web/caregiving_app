<h1>ようこそ、<%= current_user.name %> さん</h1>

<% if current_user.admin? || current_user.care_manager? %>
  <div class="actions no-print">
    <%= link_to "ケアマネージャー向けダッシュボード", dashboard_path, class: "btn btn-show" %>
    <%= link_to "全対象者カレンダー", calendar_path, class: "btn btn-secondary" %>
  </div>
<% end %>

<% if current_user.staff? %>
  <div class="panel">
    <h2>本日の訪問予定</h2>
    <% if @today_visits.present? %>
      <ul class="today-visit-list">
        <% @today_visits.each do |visit| %>
          <li>
            <span class="today-visit-time"><%= l(visit.visited_at, format: :time_only) %></span>
            <%= link_to visit.care_recipient.name, show_menu_path(care_recipient_id: visit.care_recipient_id) %>
            <span class="text-unset"><%= visit.visit_type&.name %></span>
            <% if visit.completed? %><span class="status-badge good">完了</span><% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-unset">本日の訪問予定はありません。</p>
    <% end %>
  </div>
<% end %>

<div class="panel">
  <h2>対象者を選択してください</h2>

  <% if @care_recipients.empty? %>
    <p class="text-unset">対象者が登録されていません。</p>
  <% else %>
    <div class="recipient-picker">
      <% @care_recipients.each do |care_recipient| %>
        <%= link_to show_menu_path(care_recipient_id: care_recipient.id), class: "recipient-picker-card" do %>
          <span class="recipient-picker-name"><%= care_recipient.name %></span>
          <% if care_recipient.care_level.present? %>
            <span class="recipient-picker-meta"><%= care_recipient.care_level %></span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if policy(CareRecipient).create? %>
    <div class="actions">
      <%= link_to "対象者を登録", new_care_recipient_path, class: "btn btn-new" %>
    </div>
  <% end %>
</div>
