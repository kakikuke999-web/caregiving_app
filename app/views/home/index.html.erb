<h1>ようこそ、<%= current_user.name %> さん</h1>

<% if current_user.admin? || current_user.care_manager? %>
  <p><%= link_to "ケアマネージャー向けダッシュボード", dashboard_path, class: "btn btn-show" %></p>
<% end %>

<h2>対象者を選択してください</h2>

<%= form_with url: show_menu_path, method: :post, local: true do %>
  <div class="field">
    <%= label_tag :care_recipient_id, "対象者" %><br>
    <%= select_tag :care_recipient_id, options_from_collection_for_select(CareRecipient.all, :id, :name), prompt: "選択してください" %>
  </div>

  <div class="actions">
    <%= submit_tag "メニューを表示" %>
  </div>
<% end %>

<!-- ★ ここに追加 -->
<p>
  <%= link_to "対象者を登録", new_care_recipient_path, class: "btn btn-primary" %>
</p>

<% if Rails.env.development? %>
  <p><%= link_to "ユーザー編集画面へ（開発用）", users_path, class: "btn btn-warning" %></p>
<% end %>
