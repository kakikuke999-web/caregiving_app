<%= form_with model: [care_recipient, adl_record], local: true do |f| %>
  <% if adl_record.errors.any? %>
    <div class="alert alert-danger">
      <h2><%= adl_record.errors.count %>件のエラーにより保存できませんでした:</h2>
      <ul>
        <% adl_record.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @last_adl_record.present? %>
    <p>
      <button type="button" class="btn btn-secondary" id="copy-last-adl-btn">前回の記録をコピー</button>
    </p>
    <script id="adl-last-record" type="application/json"><%= raw(@last_adl_record.attributes.to_json) %></script>
  <% end %>

  <div class="mb-3">
    <%= f.label :recorded_at, "記録日時" %>
    <%= f.datetime_field :recorded_at, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :meal_intake, "食事量" %>
    <%= f.select :meal_intake, AdlRecord.meal_intakes.keys.map { |k| [AdlRecord::MEAL_INTAKE_LABELS[k], k] }, { prompt: "選択してください" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :excretion_status, "排泄" %>
    <%= f.select :excretion_status, AdlRecord.excretion_statuses.keys.map { |k| [AdlRecord::EXCRETION_STATUS_LABELS[k], k] }, { prompt: "選択してください" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :sleep_quality, "睡眠" %>
    <%= f.select :sleep_quality, AdlRecord.sleep_qualities.keys.map { |k| [AdlRecord::SLEEP_QUALITY_LABELS[k], k] }, { prompt: "選択してください" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :note, "メモ" %>
    <%= f.text_area :note, class: "form-control" %>
  </div>

  <h3>食事摂取量（10段階）</h3>
  <div class="field-row">
    <div class="field-col">
      <%= f.label :breakfast_staple, "朝食：主食" %>
      <%= f.number_field :breakfast_staple, min: 0, max: 10, class: "form-control" %>
    </div>
    <div class="field-col">
      <%= f.label :breakfast_side, "朝食：副食" %>
      <%= f.number_field :breakfast_side, min: 0, max: 10, class: "form-control" %>
    </div>
  </div>
  <div class="field-row">
    <div class="field-col">
      <%= f.label :lunch_staple, "昼食：主食" %>
      <%= f.number_field :lunch_staple, min: 0, max: 10, class: "form-control" %>
    </div>
    <div class="field-col">
      <%= f.label :lunch_side, "昼食：副食" %>
      <%= f.number_field :lunch_side, min: 0, max: 10, class: "form-control" %>
    </div>
  </div>
  <div class="field-row">
    <div class="field-col">
      <%= f.label :dinner_staple, "夕食：主食" %>
      <%= f.number_field :dinner_staple, min: 0, max: 10, class: "form-control" %>
    </div>
    <div class="field-col">
      <%= f.label :dinner_side, "夕食：副食" %>
      <%= f.number_field :dinner_side, min: 0, max: 10, class: "form-control" %>
    </div>
  </div>

  <div class="toggle-group">
    <span class="toggle-label">入浴</span>
    <label class="toggle-option"><%= f.radio_button :bathed, true %> 有</label>
    <label class="toggle-option"><%= f.radio_button :bathed, false %> 無</label>
  </div>

  <div class="toggle-group">
    <span class="toggle-label">服薬</span>
    <label class="toggle-option"><%= f.radio_button :medication_taken, true %> 有</label>
    <label class="toggle-option"><%= f.radio_button :medication_taken, false %> 無</label>
  </div>

  <div class="field-row">
    <div class="field-col">
      <%= f.label :urination_count, "排尿（回）" %>
      <%= f.number_field :urination_count, min: 0, class: "form-control" %>
    </div>
  </div>

  <div class="toggle-group">
    <span class="toggle-label">排便</span>
    <label class="toggle-option"><%= f.radio_button :bowel_movement, true %> 有</label>
    <label class="toggle-option"><%= f.radio_button :bowel_movement, false %> 無</label>
  </div>

  <%= f.submit "保存", class: "btn btn-primary" %>
<% end %>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const copyBtn = document.getElementById('copy-last-adl-btn');
    const lastEl = document.getElementById('adl-last-record');
    if (!copyBtn || !lastEl) return;

    const last = JSON.parse(lastEl.textContent);
    const selectAndNumberFields = [
      'meal_intake', 'excretion_status', 'sleep_quality',
      'breakfast_staple', 'breakfast_side', 'lunch_staple', 'lunch_side', 'dinner_staple', 'dinner_side',
      'urination_count'
    ];
    const radioFields = ['bathed', 'medication_taken', 'bowel_movement'];

    copyBtn.addEventListener('click', function () {
      selectAndNumberFields.forEach(function (field) {
        if (last[field] === null || last[field] === undefined) return;
        const el = document.getElementById('adl_record_' + field);
        if (el) el.value = last[field];
      });
      radioFields.forEach(function (field) {
        if (last[field] === null || last[field] === undefined) return;
        const el = document.getElementById('adl_record_' + field + '_' + last[field]);
        if (el) el.checked = true;
      });
    });
  });
</script>
