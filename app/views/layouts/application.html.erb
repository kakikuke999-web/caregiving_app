<!DOCTYPE html>
<html lang="ja">
  <head>
    <title>ケアギビング</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- FullCalendar CSS -->
    <link href="https://cdn.jsdelivr.net/npm/@fullcalendar/daygrid@6.1.19/main.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <!-- ★ Rails の JS を読み込む（必須） -->
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>

    <!-- FullCalendar JS -->
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.19/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/daygrid@6.1.19/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/interaction@6.1.19/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.19/locales-all.global.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Chart.js（健康推移グラフ用） -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  </head>


  <body>
    <header class="app-header">
      <div class="app-header-bar">
        <%= link_to root_path, class: "app-brand" do %>
          <span class="app-brand-mark">C</span>
          <span>ケアギビング</span>
        <% end %>

        <% if user_signed_in? %>
          <label for="nav-toggle" class="nav-toggle-btn" aria-label="メニューを開く">☰</label>
        <% end %>
      </div>

      <% if user_signed_in? %>
        <input type="checkbox" id="nav-toggle" class="nav-toggle-checkbox">
        <div class="app-header-menu">
          <nav class="app-nav">
            <%= link_to "ホーム", root_path %>
            <% if current_user.admin? || current_user.care_manager? %>
              <%= link_to "ダッシュボード", dashboard_path %>
              <%= link_to "全対象者カレンダー", calendar_path %>
              <%= link_to "ユーザー管理", users_path %>
            <% end %>
          </nav>

          <div class="user-bar">
            <span class="user-chip"><%= current_user.email %>（<%= current_user.role_label %>）</span>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "btn btn-secondary" %>
          </div>
        </div>
      <% end %>
    </header>

    <main class="app-container">
      <% if notice %>
        <p class="notice flash"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="alert flash"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>

    <div id="photo-modal" class="photo-modal">
      <span id="photo-modal-close" class="photo-modal-close">&times;</span>
      <img id="photo-modal-img" class="photo-modal-content">
    </div>
  </body>
</html>
