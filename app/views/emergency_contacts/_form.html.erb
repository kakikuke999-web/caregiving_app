<%= form_with model: [care_recipient, emergency_contact], local: true do |f| %>
  <% if emergency_contact.errors.any? %>
    <div class="alert alert-danger">
      <h2><%= emergency_contact.errors.count %>件のエラーにより保存できませんでした:</h2>
      <ul>
        <% emergency_contact.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "氏名" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :relationship, "続柄" %>
    <%= f.text_field :relationship, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :phone_number, "電話番号" %>
    <%= f.text_field :phone_number, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :priority, "優先順位" %>
    <%= f.number_field :priority, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :note, "メモ" %>
    <%= f.text_area :note, class: "form-control" %>
  </div>

  <%= f.submit "保存", class: "btn btn-primary" %>
<% end %>
