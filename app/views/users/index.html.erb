<h2>ユーザー一覧</h2>

<table>
  <thead>
    <tr>
      <th>Email</th>
      <th>Role</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email %></td>
        <td><%= user.role.humanize %></td>
        <td><%= link_to "編集", edit_user_path(user) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
