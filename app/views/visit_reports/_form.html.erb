<%= form_with model: report, local: true do |f| %>
  <% if report.errors.any? %>
    <div class="alert alert-danger">
      <h2><%= report.errors.count %>件のエラーにより保存できませんでした:</h2>
      <ul>
        <% report.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :care_recipient_id %>

  <div class="mb-3">
    <%= f.label :visited_at, "開始時刻" %>
    <%= f.datetime_select :visited_at, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :ended_at, "終了時刻" %>
    <%= f.datetime_select :ended_at, include_blank: true, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :user_id, "担当者" %>
    <%= f.collection_select :user_id, User.assignable_to_visits.order(:name), :id, :name, prompt: "選択してください", class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :visit_type_id, "訪問タイプ" %>
    <%= f.collection_select :visit_type_id, available_visit_types, :id, :name, prompt: "選択してください", class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :notes, "内容" %>
    <%= f.text_area :notes, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :status, "ステータス" %>
    <%= f.select :status, VisitReport.statuses.keys.map { |s| [VisitReportsController::STATUS_LABELS[s], s] }, {}, class: "form-select" %>
  </div>

  <%= f.submit "保存", class: "btn btn-primary" %>
<% end %>

<% if report.persisted? && policy(report).destroy? %>
  <%= button_to "削除", report, method: :delete, data: { confirm: "この訪問記録を削除しますか？" }, class: "btn btn-delete" %>
<% end %>
