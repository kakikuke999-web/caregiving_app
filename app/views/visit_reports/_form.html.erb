<%= form_with model: report, local: true do |f| %>
  <% if report.errors.any? %>
    <div class="alert alert-danger">
      <h2><%= report.errors.count %>件のエラーにより保存できませんでした:</h2>
      <ul>
        <% report.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :care_recipient_id %>

  <div class="mb-3">
    <%= f.label :visited_at do %>開始時刻<span class="required-mark">必須</span><% end %>
    <%= f.datetime_field :visited_at, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :ended_at, "終了時刻" %>
    <%= f.datetime_field :ended_at, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :user_id, "担当者（自社スタッフ）" %>
    <%= f.collection_select :user_id, User.assignable_to_visits.order(:name), :id, :name, prompt: "選択してください", class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :provider_name, "提供事業者（自社スタッフでない場合）" %>
    <%= f.text_field :provider_name, class: "form-control", placeholder: "例: ふれんず訪問看護ステーション" %>
  </div>

  <div class="mb-3">
    <%= f.label :visit_type_id do %>訪問タイプ<span class="required-mark">必須</span><% end %>
    <%= f.collection_select :visit_type_id, available_visit_types, :id, :name, prompt: "選択してください", class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :notes, "内容" %>
    <%= f.text_area :notes, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :status, "ステータス" %>
    <%= f.select :status, VisitReport.statuses.keys.map { |s| [VisitReportsController::STATUS_LABELS[s], s] }, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <label>
      <%= f.check_box :is_monitoring %>
      モニタリング記録として記録する(毎月のモニタリング実施状況の管理に使用)
    </label>
  </div>

  <%= f.submit "保存", class: "btn btn-primary" %>
<% end %>

<% if report.persisted? %>
  <%= link_to "連絡帳（コメント）を見る・書く", visit_report_path(report), class: "btn btn-show" %>
<% end %>

<% if report.persisted? && policy(report).destroy? %>
  <%= button_to "削除", report, method: :delete, data: { confirm: "この訪問記録を削除しますか？" }, class: "btn btn-delete" %>
<% end %>
